---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    num: '01',
    title: 'Residential Electrical',
    detail: 'New builds, renovations, and upgrades. Power points, ceiling fans, switchboards, LED lighting, and full home wiring — done cleanly and safely.'
  },
  {
    num: '02',
    title: 'Commercial Electrical',
    detail: "Guyana's economy is booming. Your office, shop, or facility deserves an electrician who shows up on time, works clean, and stands behind every job."
  },
  {
    num: '03',
    title: 'AC Installation',
    detail: "In Guyana's heat, a reliable AC isn't a luxury — it's essential. We supply and install Daikin, Mitsubishi, and Fujitsu systems sized right for your space."
  },
  {
    num: '04',
    title: 'AC Servicing & Repair',
    detail: 'Regular servicing extends system life and keeps your energy bills low. We clean, gas-recharge, diagnose, and repair all major AC brands.'
  },
  {
    num: '05',
    title: 'Switchboard Upgrades',
    detail: 'An old switchboard is a fire waiting to happen. We upgrade panels, install safety switches, replace ceramic fuses, and bring your home up to standard.'
  },
  {
    num: '06',
    title: '24/7 Emergency',
    detail: "Burning smells, tripped breakers, exposed wires — don't wait. We respond fast, day or night, because some problems can't wait until morning."
  },
];

const stats = [
  { val: '100%', label: 'Work Guaranteed'  },
  { val: 'Free', label: 'Every Quote'      },
  { val: '24/7', label: 'Emergency Line'   },
  { val: 'GY',   label: 'Licensed & Local' },
];

const testimonials = [
  {
    quote: 'Fast, professional, and honest about pricing. They installed two AC units in our office and had everything running perfectly the same day. Very impressed.',
    name: 'Priya M.',
    role: 'Business Owner, Georgetown',
  },
  {
    quote: 'Called them at 10pm for a wiring fault. They were at my door within the hour. Sorted the issue quickly and charged a fair price. Highly recommended.',
    name: 'Trevor H.',
    role: 'Homeowner, East Bank Demerara',
  },
  {
    quote: 'Had them rewire our clinic ahead of inspection. Clean work, no mess left behind, and they explained everything they did. Finally found electricians we can trust.',
    name: 'Dr. Sandra R.',
    role: 'Clinic Director, Georgetown',
  },
];

const marqueeItems = ['RESIDENTIAL', 'COMMERCIAL', 'AC INSTALLATION', 'AC REPAIRS', '24/7 EMERGENCY', 'LICENSED', 'SWITCHBOARDS', 'LED LIGHTING', 'GUYANA', 'GEORGETOWN'];
---

<Layout
  title="Electrician Georgetown Guyana | MP Electrical & AC Contractors"
  description="MP Electrical & Air Conditioning — licensed electricians and AC contractors in Georgetown, Guyana. Residential, commercial & 24/7 emergency services. Free quotes. Call 592 652-2032."
  canonicalPath="/"
>
  <Nav />

  <!-- ── HERO ──────────────────────────────────────────────── -->
  <section class="hero-bg min-h-screen flex flex-col" id="hero">
    <div class="glow-orb glow-orb-1"></div>
    <div class="glow-orb glow-orb-2"></div>

    <div class="relative z-10 flex-1 flex flex-col max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 pb-16 pt-40">

      <!-- Badge -->
      <div class="mb-auto">
        <span class="lime-badge">
          <span class="lime-dot"></span>
          Now Open · 75 Light Street, Georgetown
        </span>
      </div>

      <!-- Main headline -->
      <div class="mt-auto grid lg:grid-cols-12 items-end gap-8">
        <div class="lg:col-span-8">
          <p class="section-label mb-5">Electrical · Air Conditioning · Supplies</p>
          <h1 class="display-xl" style="color:#F0F0E8;">
            Guyana is<br/>
            building.<br/>
            <span style="color:#CBFF5E;">Wire it right.</span>
          </h1>
          <p class="mt-6 text-lg leading-relaxed max-w-xl" style="color:#7A8C7A;">
            Georgetown's new standard in licensed electrical and AC contracting. Honest pricing, guaranteed workmanship, and a team that actually shows up — for homes, businesses, and everything in between.
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-3">
            <a href="/contact" class="btn-lime px-8 py-4 rounded-full text-base" style="text-decoration:none;">
              Get a Free Quote
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
            <a
              href="https://wa.me/5926522032"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-4 rounded-full text-base font-semibold transition-all"
              style="background:rgba(37,211,102,0.1); color:#25D366; border:1px solid rgba(37,211,102,0.25); text-decoration:none;"
              onmouseover="this.style.background='rgba(37,211,102,0.18)'"
              onmouseout="this.style.background='rgba(37,211,102,0.1)'"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
              WhatsApp
            </a>
          </div>
        </div>

        <!-- CTA circle -->
        <div class="lg:col-span-4 flex justify-end items-end">
          <a
            href="tel:+5926522032"
            class="group relative w-36 h-36 rounded-full flex flex-col items-center justify-center border transition-all duration-300"
            style="border-color:rgba(203,255,94,0.3); background:rgba(203,255,94,0.05); text-decoration:none;"
            onmouseover="this.style.background='rgba(203,255,94,0.12)'; this.style.borderColor='rgba(203,255,94,0.6)'"
            onmouseout="this.style.background='rgba(203,255,94,0.05)'; this.style.borderColor='rgba(203,255,94,0.3)'"
          >
            <svg class="w-6 h-6 mb-2" style="color:#CBFF5E;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <span class="text-xs font-semibold text-center leading-tight" style="color:#F0F0E8;">Call Now<br/>Free Quote</span>
            <svg class="absolute top-3 right-3 w-4 h-4 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" style="color:#CBFF5E;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="relative z-10 border-y" style="border-color:rgba(255,255,255,0.07); background:rgba(13,26,15,0.6); backdrop-filter:blur(10px);">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 divide-x" style="divide-color:rgba(255,255,255,0.07);">
          {stats.map(s => (
            <div class="py-6 px-4 sm:px-8 text-center">
              <div class="stat-val display-md" style="color:#CBFF5E;">{s.val}</div>
              <div class="text-xs mt-1 uppercase tracking-widest" style="color:#7A8C7A;">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── MARQUEE STRIP ──────────────────────────────────────── -->
  <div class="py-4 overflow-hidden" style="background:#CBFF5E;">
    <div class="marquee-wrapper">
      <div class="marquee-track">
        {[...marqueeItems, ...marqueeItems].map(item => (
          <span class="inline-flex items-center gap-4 px-6 text-sm font-bold uppercase tracking-widest whitespace-nowrap" style="color:#060C07;">
            {item}
            <span style="color:rgba(6,12,7,0.3);">●</span>
          </span>
        ))}
      </div>
    </div>
  </div>

  <!-- ── SERVICES ───────────────────────────────────────────── -->
  <section class="py-28" style="background:#060C07;" id="services">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-12 gap-8 mb-16">
        <div class="lg:col-span-7">
          <p class="section-label mb-4">What We Do</p>
          <h2 class="display-lg" style="color:#F0F0E8;">
            Every electrical<br/>need, covered.
          </h2>
        </div>
        <div class="lg:col-span-5 flex items-end">
          <p class="text-base leading-relaxed" style="color:#7A8C7A;">
            From a single power point to a full commercial fit-out — we bring the same care, professionalism, and guaranteed workmanship to every job, big or small.
          </p>
        </div>
      </div>

      <div>
        {services.map(s => (
          <div class="service-row flex items-start gap-6 sm:gap-10 py-6 sm:py-8 px-2 group">
            <span class="service-row-num text-xs font-mono mt-1 shrink-0 transition-colors" style="color:#4A5A4A;">{s.num}</span>
            <div class="flex-1 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
              <h3 class="text-xl sm:text-2xl font-semibold leading-tight" style="color:#F0F0E8;">{s.title}</h3>
              <p class="text-sm sm:max-w-xs leading-relaxed" style="color:#7A8C7A;">{s.detail}</p>
            </div>
            <svg class="w-5 h-5 shrink-0 mt-1 opacity-0 group-hover:opacity-100 transition-all group-hover:translate-x-1" style="color:#CBFF5E;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </div>
        ))}
      </div>

      <div class="mt-12 flex justify-center">
        <a href="/services" class="btn-outline-lime px-8 py-4 rounded-full text-sm" style="text-decoration:none;">
          View All Services
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── WHY CHOOSE US ─────────────────────────────────────── -->
  <section class="py-28" style="background:#0D1A0F;" id="why-us">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-20 items-center">

        <div>
          <p class="section-label mb-5">Why MP Electrical</p>
          <h2 class="display-lg mb-8" style="color:#F0F0E8;">
            The contractor<br/>
            <span style="color:#CBFF5E;">you actually want.</span>
          </h2>
          <p class="text-base leading-relaxed mb-6" style="color:#7A8C7A;">
            Guyana is going through a historic growth period — new homes, new businesses, new infrastructure. Yet too many people are still dealing with electricians who don't show up, quote one price and charge another, or leave a job half-finished.
          </p>
          <p class="text-base leading-relaxed mb-10" style="color:#7A8C7A;">
            We started MP Electrical because Guyana deserves better. Every job we do is backed by a workmanship guarantee, an upfront quote, and a team that actually picks up the phone.
          </p>
          <a href="/about" class="btn-lime px-8 py-4 rounded-full text-sm inline-flex items-center gap-2" style="text-decoration:none;">
            Our Story
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {[
            {
              svg: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>`,
              title: "Licensed & Insured",
              body: "All work is carried out by qualified, licensed electricians. Fully insured — protecting you, your property, and our team."
            },
            {
              svg: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>`,
              title: "24/7 Emergency Line",
              body: "Electrical emergencies don't wait for business hours. Call us any time — we will answer and we will come."
            },
            {
              svg: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z"/></svg>`,
              title: "Upfront Pricing",
              body: "We quote before we start and stick to it. No hidden extras, no surprise invoice at the end. Always."
            },
            {
              svg: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z"/></svg>`,
              title: "Workmanship Guarantee",
              body: "Not happy with something? We come back and fix it at no charge. We stand behind every single job we do."
            },
          ].map(f => (
            <div class="card-dark rounded-2xl p-6">
              <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5" style="background:rgba(203,255,94,0.08); border:1px solid rgba(203,255,94,0.15); color:#CBFF5E;" set:html={f.svg}></div>
              <h3 class="font-semibold mb-2 text-base" style="color:#F0F0E8;">{f.title}</h3>
              <p class="text-sm leading-relaxed" style="color:#7A8C7A;">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── TESTIMONIALS ──────────────────────────────────────── -->
  <section class="py-28" style="background:#060C07;" id="testimonials">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="section-label mb-4">What Clients Say</p>
        <h2 class="display-md" style="color:#F0F0E8;">Real people.<br/>Real results.</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {testimonials.map(t => (
          <div class="card-dark rounded-2xl p-8 flex flex-col">
            <svg class="w-8 h-8 mb-6 shrink-0" style="color:#CBFF5E;" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
            </svg>
            <p class="text-base leading-relaxed flex-1 mb-6" style="color:#B0BDB0;">{t.quote}</p>
            <div class="border-t pt-4" style="border-color:rgba(255,255,255,0.07);">
              <div class="font-semibold text-sm" style="color:#F0F0E8;">{t.name}</div>
              <div class="text-xs mt-0.5" style="color:#7A8C7A;">{t.role}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA BANNER ────────────────────────────────────────── -->
  <section class="py-24" style="background:#CBFF5E;" id="cta">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-8">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest mb-3" style="color:rgba(6,12,7,0.5);">Ready to Start?</p>
          <h2 class="display-md leading-tight" style="color:#060C07;">
            Let's get your project<br/>powered up.
          </h2>
          <p class="mt-3 text-base" style="color:rgba(6,12,7,0.6);">Free quotes. No obligation. Same-day response.</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 shrink-0">
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-full text-sm font-semibold transition-all"
            style="background:#060C07; color:#CBFF5E; text-decoration:none;"
            onmouseover="this.style.background='#0D1A0F'"
            onmouseout="this.style.background='#060C07'"
          >
            Get a Free Quote
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a
            href="tel:+5926522032"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-full text-sm font-semibold border transition-all"
            style="border-color:rgba(6,12,7,0.25); color:#060C07; text-decoration:none;"
            onmouseover="this.style.background='rgba(6,12,7,0.08)'"
            onmouseout="this.style.background='transparent'"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            592 652-2032
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
