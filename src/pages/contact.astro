---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Get a Free Quote | Electrician Georgetown Guyana — MP Electrical"
  description="Contact MP Electrical & Air Conditioning in Georgetown, Guyana. Call 592 652-2032 or WhatsApp us for a free quote. 24/7 emergency electrician available."
  canonicalPath="/contact"
>
  <Nav />

  <!-- Page Hero -->
  <section class="hero-bg pt-40 pb-16 relative overflow-hidden">
    <div class="glow-orb glow-orb-1" style="opacity:0.5;"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="section-label mb-5">Get In Touch</p>
      <h1 class="display-xl max-w-3xl" style="color:#F0F0E8;">
        Let's talk<br/>
        <span style="color:#CBFF5E;">your project.</span>
      </h1>
      <p class="mt-6 text-lg max-w-lg leading-relaxed" style="color:#7A8C7A;">
        Whether you need a quote, want to book a job, or have an emergency — we are here to help. Response within 1 business hour.
      </p>
    </div>
  </section>

  <!-- Main contact section -->
  <section class="py-28" style="background:#060C07;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-12 gap-16">

        <!-- Left: contact details -->
        <div class="lg:col-span-4 space-y-10">

          <!-- Direct contact -->
          <div>
            <p class="section-label mb-6">Direct Contact</p>
            <div class="space-y-5">
              <a href="tel:+5926522032" class="flex items-start gap-4 group" style="text-decoration:none;">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 mt-0.5" style="background:rgba(203,255,94,0.1); border:1px solid rgba(203,255,94,0.15);">
                  <svg class="w-4 h-4" style="color:#CBFF5E;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs uppercase tracking-widest mb-1" style="color:#4A5A4A;">Phone</div>
                  <div class="font-semibold transition-colors group-hover:text-lime" style="color:#F0F0E8;">592 652-2032</div>
                  <div class="text-xs mt-0.5" style="color:#7A8C7A;">Mon–Fri 7am–6pm · Sat 8am–4pm</div>
                </div>
              </a>

              <a href="mailto:mpelectrical2003@gmail.com" class="flex items-start gap-4 group" style="text-decoration:none;">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 mt-0.5" style="background:rgba(203,255,94,0.1); border:1px solid rgba(203,255,94,0.15);">
                  <svg class="w-4 h-4" style="color:#CBFF5E;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs uppercase tracking-widest mb-1" style="color:#4A5A4A;">Email</div>
                  <div class="font-semibold transition-colors group-hover:text-lime" style="color:#F0F0E8;">mpelectrical2003@gmail.com</div>
                  <div class="text-xs mt-0.5" style="color:#7A8C7A;">Reply within 1 business hour</div>
                </div>
              </a>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 mt-0.5" style="background:rgba(203,255,94,0.1); border:1px solid rgba(203,255,94,0.15);">
                  <svg class="w-4 h-4" style="color:#CBFF5E;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs uppercase tracking-widest mb-1" style="color:#4A5A4A;">Location</div>
                  <div class="font-semibold" style="color:#F0F0E8;">75 Light Street</div>
                  <div class="text-sm" style="color:#F0F0E8;">Georgetown, Guyana</div>
                  <div class="text-xs mt-0.5" style="color:#7A8C7A;">Serving all regions of Guyana</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Emergency -->
          <div class="rounded-2xl p-6" style="background:#0D1A0F; border:1px solid rgba(203,255,94,0.15);">
            <div class="flex items-center gap-2 mb-3">
              <span class="lime-dot"></span>
              <span class="section-label">24/7 Emergency</span>
            </div>
            <p class="text-sm leading-relaxed mb-4" style="color:#7A8C7A;">
              For urgent electrical faults, power outages, or dangerous conditions — call our emergency line immediately.
            </p>
            <div class="flex flex-col gap-2">
              <a href="tel:+5926522032" class="btn-lime w-full py-3 rounded-xl text-sm text-center inline-block" style="text-decoration:none;">
                Call 592 652-2032
              </a>
              <a href="https://wa.me/5926522032" target="_blank" rel="noopener noreferrer" class="w-full py-3 rounded-xl text-sm text-center inline-flex items-center justify-center gap-2 font-semibold transition-all" style="background:rgba(37,211,102,0.12); color:#25D366; border:1px solid rgba(37,211,102,0.25); text-decoration:none;" onmouseover="this.style.background='rgba(37,211,102,0.2)'" onmouseout="this.style.background='rgba(37,211,102,0.12)'">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                </svg>
                WhatsApp Us
              </a>
            </div>
          </div>

          <!-- Hours -->
          <div>
            <p class="section-label mb-5">Business Hours</p>
            <div class="space-y-3 text-sm">
              {[
                { days: "Monday – Friday",  hours: "7:00 AM – 6:00 PM" },
                { days: "Saturday",         hours: "8:00 AM – 4:00 PM" },
                { days: "Sunday / Holidays",hours: "Emergency Only"    },
              ].map(h => (
                <div class="flex items-center justify-between py-2 border-b" style="border-color:rgba(255,255,255,0.06);">
                  <span style="color:#7A8C7A;">{h.days}</span>
                  <span class="font-medium" style={h.hours === "Emergency Only" ? "color:#CBFF5E;" : "color:#F0F0E8;"}>{h.hours}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Right: Quote Form -->
        <div class="lg:col-span-8">
          <div class="rounded-3xl p-8 sm:p-10" style="background:#0D1A0F; border:1px solid rgba(255,255,255,0.07);">
            <p class="section-label mb-2">Free Quote</p>
            <h2 class="display-md mb-8" style="color:#F0F0E8;">Request a quote</h2>

            <form
              action="https://api.web3forms.com/submit"
              method="POST"
              id="quote-form"
              class="space-y-5"
            >
              <!-- Web3Forms hidden fields -->
              <input type="hidden" name="access_key" value="03d5f3b2-87ae-44c0-a946-dee744abbea0" />
              <input type="hidden" name="subject" value="New Quote Request — MP Electrical & Air Conditioning" />
              <input type="hidden" name="from_name" value="MP Electrical Website" />
              <input type="hidden" name="redirect" value="false" />
              <!-- Honeypot spam protection -->
              <input type="checkbox" name="botcheck" style="display:none;" />

              <!-- Name + Phone row -->
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-xs uppercase tracking-widest mb-2" style="color:#7A8C7A;" for="name">Full Name *</label>
                  <input
                    type="text" id="name" name="name" required
                    placeholder="Your name"
                    class="w-full px-4 py-3 rounded-xl text-sm outline-none transition-all"
                    style="background:#142018; border:1px solid rgba(255,255,255,0.08); color:#F0F0E8;"
                    onfocus="this.style.borderColor='rgba(203,255,94,0.4)'"
                    onblur="this.style.borderColor='rgba(255,255,255,0.08)'"
                  />
                </div>
                <div>
                  <label class="block text-xs uppercase tracking-widest mb-2" style="color:#7A8C7A;" for="phone">Phone Number</label>
                  <input
                    type="tel" id="phone" name="phone"
                    placeholder="592 XXX-XXXX"
                    class="w-full px-4 py-3 rounded-xl text-sm outline-none transition-all"
                    style="background:#142018; border:1px solid rgba(255,255,255,0.08); color:#F0F0E8;"
                    onfocus="this.style.borderColor='rgba(203,255,94,0.4)'"
                    onblur="this.style.borderColor='rgba(255,255,255,0.08)'"
                  />
                </div>
              </div>

              <!-- Email -->
              <div>
                <label class="block text-xs uppercase tracking-widest mb-2" style="color:#7A8C7A;" for="email">Email Address *</label>
                <input
                  type="email" id="email" name="email" required
                  placeholder="you@example.com"
                  class="w-full px-4 py-3 rounded-xl text-sm outline-none transition-all"
                  style="background:#142018; border:1px solid rgba(255,255,255,0.08); color:#F0F0E8;"
                  onfocus="this.style.borderColor='rgba(203,255,94,0.4)'"
                  onblur="this.style.borderColor='rgba(255,255,255,0.08)'"
                />
              </div>

              <!-- Service type -->
              <div>
                <label class="block text-xs uppercase tracking-widest mb-2" style="color:#7A8C7A;" for="service">Service Required *</label>
                <select
                  id="service" name="service" required
                  class="w-full px-4 py-3 rounded-xl text-sm outline-none transition-all appearance-none"
                  style="background:#142018; border:1px solid rgba(255,255,255,0.08); color:#F0F0E8;"
                  onfocus="this.style.borderColor='rgba(203,255,94,0.4)'"
                  onblur="this.style.borderColor='rgba(255,255,255,0.08)'"
                >
                  <option value="" style="background:#142018;">Select a service...</option>
                  <option value="residential" style="background:#142018;">Residential Electrical</option>
                  <option value="commercial" style="background:#142018;">Commercial Electrical</option>
                  <option value="ac-install" style="background:#142018;">AC Installation</option>
                  <option value="ac-service" style="background:#142018;">AC Servicing / Repair</option>
                  <option value="switchboard" style="background:#142018;">Switchboard Upgrade</option>
                  <option value="led" style="background:#142018;">LED Lighting</option>
                  <option value="emergency" style="background:#142018;">Emergency / Other</option>
                </select>
              </div>

              <!-- Location -->
              <div>
                <label class="block text-xs uppercase tracking-widest mb-2" style="color:#7A8C7A;" for="location">Property Location</label>
                <input
                  type="text" id="location" name="location"
                  placeholder="Georgetown, East Bank, Berbice..."
                  class="w-full px-4 py-3 rounded-xl text-sm outline-none transition-all"
                  style="background:#142018; border:1px solid rgba(255,255,255,0.08); color:#F0F0E8;"
                  onfocus="this.style.borderColor='rgba(203,255,94,0.4)'"
                  onblur="this.style.borderColor='rgba(255,255,255,0.08)'"
                />
              </div>

              <!-- Message -->
              <div>
                <label class="block text-xs uppercase tracking-widest mb-2" style="color:#7A8C7A;" for="message">Job Description *</label>
                <textarea
                  id="message" name="message" rows="4" required
                  placeholder="Tell us about your project or issue..."
                  class="w-full px-4 py-3 rounded-xl text-sm outline-none transition-all resize-none"
                  style="background:#142018; border:1px solid rgba(255,255,255,0.08); color:#F0F0E8;"
                  onfocus="this.style.borderColor='rgba(203,255,94,0.4)'"
                  onblur="this.style.borderColor='rgba(255,255,255,0.08)'"
                ></textarea>
              </div>

              <button
                type="submit"
                id="submit-btn"
                class="btn-lime w-full py-4 rounded-xl text-sm font-semibold"
              >
                <span id="btn-text" class="inline-flex items-center gap-2 justify-center">
                  Send Request
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                  </svg>
                </span>
                <span id="btn-loading" class="items-center gap-2 justify-center" style="display:none;">
                  <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                  </svg>
                  Sending...
                </span>
              </button>

              <!-- Success message -->
              <div id="form-success" class="hidden rounded-xl p-4 text-sm text-center font-medium" style="background:rgba(203,255,94,0.1); color:#CBFF5E; border:1px solid rgba(203,255,94,0.25);">
                ✓ Message sent! We'll be in touch within 1 business hour.
              </div>
              <!-- Error message -->
              <div id="form-error" class="hidden rounded-xl p-4 text-sm text-center font-medium" style="background:rgba(239,68,68,0.1); color:#f87171; border:1px solid rgba(239,68,68,0.2);">
                Something went wrong. Please try again or call us directly.
              </div>

              <p class="text-xs text-center" style="color:#4A5A4A;">
                We'll respond within 1 business hour. For emergencies, call directly.
              </p>
            </form>

<script>
  const form = document.getElementById('quote-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text') as HTMLElement;
  const btnLoading = document.getElementById('btn-loading') as HTMLElement;
  const successMsg = document.getElementById('form-success') as HTMLElement;
  const errorMsg = document.getElementById('form-error') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    btnText.style.display = 'none';
    btnLoading.style.display = 'inline-flex';
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    const data = new FormData(form);
    try {
      const res = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: data });
      const json = await res.json();
      if (json.success) {
        form.reset();
        successMsg.classList.remove('hidden');
      } else {
        errorMsg.classList.remove('hidden');
      }
    } catch {
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      btnText.style.display = '';
      btnLoading.style.display = 'none';
    }
  });
</script>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── GOOGLE MAP ─────────────────────────────────────── -->
  <section style="background:#060C07; padding-bottom:0;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-28">
      <p class="section-label mb-6">Find Us</p>
      <h2 class="display-md mb-8" style="color:#F0F0E8;">75 Light Street,<br/><span style="color:#CBFF5E;">Georgetown.</span></h2>
      <div class="rounded-2xl overflow-hidden" style="border:1px solid rgba(255,255,255,0.08);">
        <iframe
          src="https://maps.google.com/maps?q=75+Light+Street,+Georgetown,+Guyana&t=&z=16&ie=UTF8&iwloc=&output=embed"
          width="100%"
          height="420"
          style="border:0; display:block; filter:invert(90%) hue-rotate(180deg);"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="MP Electrical & Air Conditioning — 75 Light Street, Georgetown, Guyana"
        ></iframe>
      </div>
      <p class="mt-4 text-sm" style="color:#7A8C7A;">75 Light Street, Georgetown, Guyana &middot; <a href="https://maps.google.com/maps?q=75+Light+Street,+Georgetown,+Guyana" target="_blank" rel="noopener noreferrer" style="color:#CBFF5E; text-decoration:none;">Open in Google Maps ↗</a></p>
    </div>
  </section>

  <Footer />
</Layout>
